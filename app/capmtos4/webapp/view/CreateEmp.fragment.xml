<core:FragmentDefinition xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">
    <Dialog title="Create Employee" contentWidth="50%" contentHeight="70%">
        <f:SimpleForm editable="true" layout="ResponsiveGridLayout" labelSpanL="3" labelSpanM="3" emptySpanL="3" emptySpanM="3">
            <f:content>
                <Label text="Employee ID"></Label>
                <Input value="{Empid}"></Input>
                <Label text="Name"></Label>
                <Input value="{Name}"></Input>
                <Label text="Designation"></Label>
                <Input value="{Desig}"></Input>
                <Label text="Email"></Label>
                <Input value="{Email}"></Input>
                <Label text="Status"></Label>
                <Input value="{Status}"></Input>
            </f:content>
        </f:SimpleForm>
        <beginButton>
            <Button text="Save" type="Emphasized" press="onPressSave"></Button>
        </beginButton>
        <endButton>
            <Button text="Cancel" type="Reject" press="onPressCancel"></Button>
        </endButton>
    </Dialog>


</core:FragmentDefinition>